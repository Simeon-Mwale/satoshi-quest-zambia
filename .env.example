# =============================================
# SatoshiQuest Zambia — Environment Variables
# Copy this file to .env.local and fill in values
# NEVER commit .env.local to git
# =============================================

# --- Database ---
# SQLite (local dev — file will be created automatically)
DATABASE_URL="file:./dev.db"

# Supabase (production — replace with your project URL)
# DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# --- Lightning Rewards (optional — for real sats payouts) ---
# OpenNode (easiest for Africa)
OPENNODE_API_KEY=""
OPENNODE_ENV="dev"  # change to "live" for production

# BTCPay Server (self-hosted)
BTCPAY_URL=""
BTCPAY_API_KEY=""
BTCPAY_STORE_ID=""

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# In production: NEXT_PUBLIC_APP_URL="https://satoshiquest.vercel.app"

# --- Optional: Admin ---
ADMIN_SECRET=""  # used to protect any admin-only API routes
